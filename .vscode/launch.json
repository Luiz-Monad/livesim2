{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "PowerShell: Interactive Session",
            "type": "PowerShell",
            "request": "launch",
            "cwd": "${cwd}"
        },
        {
            "name": "Go: Attach to Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": "${command:pickGoProcess}"
        },
        {
            "name": "livesim [test]",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/livesim2/main.go",
            "cwd": "${workspaceFolder}/cmd/livesim2/app",
            "args": [
                "--cfg",
                "${workspaceFolder}/e2e-test/data/out/config.json",
                "--loglevel",
                "debug",
                "--logformat",
                "pretty",
            ]
        },
        {
            "name": "livesim",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/livesim2/main.go",
            "cwd": "${workspaceFolder}/cmd/livesim2/app",
            "args": [
                "--cfg",
                "${workspaceFolder}/cmd/livesim2/config.json",
                "--loglevel",
                "debug",
                "--logformat",
                "pretty",
            ]
        },
        {
            "name": "cmaf-ingest-receiver",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/cmaf-ingest-receiver/main.go",
            "cwd": "${workspaceFolder}/cmd/cmaf-ingest-receiver",
            "args": [
                "--port",
                "6080",
                "--porthttps",
                "6443",
                "--fileserverpath",
                "media",
                "--loglevel",
                "debug",
                "--logformat",
                "pretty",
            ],
        },
        {
            "name": "dash-fetcher",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/dash-fetcher/main.go",
            "cwd": "${workspaceFolder}/cmd/dash-fetcher",
            "args": [
                "--auto",
                "https://dash.akamaized.net/WAVE/vectors/cfhd_sets/12.5_25_50/t1/2022-10-17/stream.mpd",
                "--loglevel",
                "debug",
            ],
        }
    ]
}